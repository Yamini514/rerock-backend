# Merock Realty backend — environment configuration
# Copy this file to .env and fill in real values. .env is git-ignored.

# Postgres connection string (Neon). Example:
# postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DB_URL=

# Secret used to sign JWT auth tokens. Generate a strong random value:
#   ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
JWT_SECRET=

# Runtime environment: development | production
RACK_ENV=development

# Connection pool size (optional)
POOL_SIZE=5

# AWS (only needed if S3 media upload is enabled)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
# Bucket used for property image uploads (see App::Services::Uploads). Must
# allow public-read ACLs, or swap put_object's acl for a bucket policy instead.
AWS_S3_BUCKET=

# SMTP (only needed when email notifications are enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# CORS allowlist — comma-separated frontend origins for production, e.g.
#   ALLOWED_ORIGINS=https://app.rerockrealty.com,https://rerockrealty.com
# Leave empty in development to allow all origins.
ALLOWED_ORIGINS=

# Base URL of the frontend, used in password-reset email links, e.g.
#   FRONTEND_URL=https://app.rerockrealty.com
FRONTEND_URL=
